#!/usr/bin/python
import struct

# operators in precedence order
INFIX_LEVEL = {
	"=":   0,
	"|":   1,
	"^":   2,
	"&":   3,
	"==":  4,
	"!=":  5,
	"<":   7,
	">":   7,
	"<=":  9,
	">=":  9,
	"<<": 11,
	">>": 11,
	"+":  13,
	"-":  13,
	"*":  16,
	"/":  16,
	"%":  16,
}

STMT_TYPES = [
	"block",
	"return",
]

EXPR_TYPES = INFIX_LEVEL.keys() + [
	"number",
	"neg",
	"not",
	"call",
	"use",
]


class Node:

	def __init__(self, type):
		self.type = type
		self.kids = []
		self.parent = None

	def add(self, kid):
		kid.parent = self
		self.kids.append(kid)
		return self

	def pretty_print(self, indent=0):
		line = " " * indent + self.type
		if hasattr(self, "name"):   line += " %r" % self.name
		if hasattr(self, "number"): line += " %d" % self.number
		print line
		for k in self.kids:
			k.pretty_print(indent + 1)

	def is_lvalue(self):
		return self.type == "use"

	def is_stmt(self): return self.type in STMT_TYPES
	def is_expr(self): return self.type in EXPR_TYPES


KEYWORDS = [
	"return",
	"if",
	"else",
	"while",
	"for",
	"break",
	"continue",
	"enum",
]


class Lexer:
	def __init__(self, code):
		self._code = code
		self._pos  = 0
		self._row  = 1
		self._col  = 1

		self.tok  = ""
		self.name = ""
		self.number = 0

		self.next()

	def error(self, msg = ""):
		print "error at %d:%d: " % (self._last_row, self._last_col) + msg
		exit(1)

	def next(self):
		self.tok = self.scan()

	def char(self):
		return self._code[self._pos : self._pos + 1]

	def next_char(self):
		c = self.char()
		if not c: return ""
		if self._code[self._pos] == "\n":
			self._row += 1
			self._col = 1
		else:
			self._col += 1
		self._pos += 1
		return c

	def scan(self):
		while self.char():
			self._last_row = self._row
			self._last_col = self._col
			c = self.next_char()

			if c.isalpha() or c == '_':
				self.name = c
				while self.char().isalnum() or self.char() == '_':
					self.name += self.next_char()
				if self.name in KEYWORDS: return self.name
				return "id"

			if c.isdigit():
				self.number = int(c)
				while self.char().isdigit():
					self.number = self.number * 10 + int(self.next_char())
				return "number"

			if c in "+-*%(){};~,": return c
			if c == "/":
				if self.char() != '/': return "/";
				while self.char() and self.char() != "\n": self.next_char()
				continue

			if c in "<>":
				if self.char() not in c + "=": return c
				return c + self.next_char()

			if c in "!=":
				if self.char() != "=": return c
				return c + self.next_char()

			if not c.isspace():
				self.error("unexpected character %r" % c)

		return ""



class Parser(Lexer):
	def __init__(self, code):
		Lexer.__init__(self, code)

	def parse(self):

		self.enum = {}
		prog = Node("program")

		while self.tok:

			if self.tok == "enum":
				self.next()
				self.match("{")
				i = 0
				while self.tok != "}":
					n = self.name
					self.match("id")
					if self.tok == "=":
						self.next()
						self.match("number")
						i = self.number
					self.enum[n] = i
					i += 1
					if self.tok == ",":
						self.next()
						continue
					break
				self.match("}")
				self.match(";")


			# read type and name
			t = self.name
			self.match("id")
			n = self.name
			self.match("id")

			# function
			if self.tok == "(":
				self.next()
				node = Node("func")
				if t not in ("void", "int"): self.error("invalid type")
				node.t = t
				node.name = n
				# TODO: arguments
				self.match(")")
				if self.tok != "{": self.error("no function block")

				node.add(self.stmt())
				prog.add(node)
				continue

			# variable
			if t not in ("int"): self.error("invalid type")
			node = Node("var")
			node.t = t
			node.name = n
			self.match(";")
			prog.add(node)
			continue

		return prog


	def stmt(self):

		if self.tok == "return":
			self.next()
			node = Node("return")
			if self.tok != ";": node.add(self.expr())
			self.match(";")
			return node

		elif self.tok == "for":
			self.next()
			# fake for loop by using a while loop
			node = Node("block")
			self.match("(")
			node.add(self.expr())
			self.match(";")
			w = Node("while")
			node.add(w)
			w.add(self.expr())
			self.match(";")
			i = self.expr()
			self.match(")")
			b = Node("block")
			w.add(b)
			b.add(self.stmt())
			b.add(i)
			return node

		elif self.tok == "while":
			self.next()
			node = Node("while")
			self.match("(")
			node.add(self.expr())
			self.match(")")
			node.add(self.stmt())
			return node

		elif self.tok == "if":
			self.next()
			node = Node("if")
			self.match("(")
			node.add(self.expr())
			self.match(")")
			node.add(self.stmt())
			if self.tok == "else":
				self.next()
				node.add(self.stmt())
			return node

		elif self.tok == "{":
			self.next()
			node = Node("block")
			while self.tok != "}": node.add(self.stmt())
			self.next()
			return node

		else:
			node = self.expr()
			self.match(";")
			return node

	def expr(self, level=0):

		# unary stuff
		if self.tok == "number":
			self.next()
			node = Node("number")
			node.number = self.number
		elif self.tok == "+":
			self.next()
			node = self.expr(99)
		elif self.tok == "-":
			self.next()
			node = Node("neg").add(self.expr(99))
		elif self.tok == "(":
			self.next()
			node = self.expr()
			self.match(")")
		elif self.tok == "!":
			self.next()
			node = Node("not").add(self.expr(99))
		elif self.tok == "id":
			self.next()
			if self.tok == "(":
				node = Node("call")
				node.name = self.name
				self.next()
				# TODO: args
				self.match(")")
			else:
				if self.name in self.enum:
					node = Node("number")
					node.number = self.enum[self.name]
				else:
					node = Node("use")
					node.name = self.name
		else:
			self.error("bad expression %r" % self.tok)

		# infix stuff
		while self.tok in INFIX_LEVEL and INFIX_LEVEL[self.tok] >= level:
			tok = self.tok
			self.next()
			node = Node(tok).add(node).add(self.expr(INFIX_LEVEL[tok] + 1))
		return node

	def match(self, tok):
		if tok != self.tok: self.error("unexpected token %r (should be %r)" % (self.tok, tok))
		self.next()



def resolve_names(node):
	for k in node.kids: resolve_names(k)

	if node.type == "use":
		n = node
		while n.parent:
			kid = n
			n = n.parent
		for k in n.kids:
			assert k != kid, "use of undefined variable %r" % node.name
			if k.type == "var" and k.name == node.name:
				node.var = k
				break

	elif node.type == "call":
		n = node
		while n.parent: n = n.parent
		for k in n.kids:
			if k.type == "func" and k.name == node.name:
				node.func = k
				break
		else:
			assert False, "call of undefined function %r" % node.name


def check_types(node):
	for k in node.kids: check_types(k)

	if node.type == "return":
		t = node.kids[0].t if node.kids else "void"
		n = node.parent
		while n.type != "func": n = n.parent
		assert n.t == t, "return type mismatch"
		# TODO: check for missing return statement somehow

	if not node.is_expr(): return
	if   node.type == "number": node.t = "int"
	elif node.type == "use":    node.t = node.var.t
	elif node.type == "call":   node.t = node.func.t
	else:
		node.t = node.kids[0].t
		# all children must have the same expression type
		assert all(k.t == node.t for k in node.kids), "type mismatch"
		assert node.t != "void"


def fold_constants(node):
	for k in node.kids: fold_constants(k)
	if not all(k.type == "number" for k in node.kids): return
	if node.type in ("+", "-", "*", "/", "%"):
		node.number = eval("%d %s %d" % (node.kids[0].number, node.type, node.kids[1].number))
		node.type = "number"
	# TODO: handle other operators


OPCODES = [
    "IMM", "LI", "SI", "PUSH",
    "JMP", "JZ", "JNZ", "CALL", "RET",
    "INC", "DEC", "NOT", "NEG",
    #"OR", "XOR", "AND", "EQ", "NE", "LT", "LE", "GT", "GE", "SHL", "SHR", "ADD", "SUB", "MUL", "DIV", "MOD",
    "|", "^", "&", "==", "!=", "<", "<=", ">", ">=", "<<", ">>", "+", "-", "*", "/", "%",
]

OPCODES_ = [
    "IMM", "LI", "SI", "PUSH",
    "JMP", "JZ", "JNZ", "CALL", "RET",
    "INC", "DEC", "NOT", "NEG",
    "OR", "XOR", "AND", "EQ", "NE", "LT", "LE", "GT", "GE", "SHL", "SHR", "ADD", "SUB", "MUL", "DIV", "MOD",
    #"|", "^", "&", "==", "!=", "<", "<=", ">", ">=", "<<", ">>", "+", "-", "*", "/", "%",
]



OT = dict((o, i) for i, o in enumerate(OPCODES))


def compile(prog):
	assert prog.type == "program"

	var_offset = 0
	bytecode = []
	def emit(b):
		if type(b) == int: bytecode.append(b)
		else: bytecode.append(OT[b])

	linking = []

	def cmpl(node):
		if node.type == "func":
			node.address = len(bytecode)
			blk = node.kids[0]
			cmpl(blk)
			if not blk.kids or blk.kids[-1].type != "return": emit("RET")

		elif node.type == "block":
			for k in node.kids: cmpl(k)

		elif node.type == "return":
			if node.kids: cmpl(node.kids[0])
			emit("RET")

		elif node.type == "while":
			s = len(bytecode)
			if node.kids[0].type == "number" and node.kids[0].number != 0:
				# condition is always true
				a = None
			else:
				cmpl(node.kids[0])
				emit("JZ")
				a = len(bytecode)
				emit(0)
			cmpl(node.kids[1])
			emit("JMP")
			emit(s)
			if a:
				bytecode[a] = len(bytecode)

		elif node.type == "if":
			cmpl(node.kids[0])
			emit("JZ")
			a = len(bytecode)
			emit(0)
			cmpl(node.kids[1])
			# else
			if len(node.kids) == 3:
				bytecode[a] = len(bytecode) + 2
				emit("JMP")
				a = len(bytecode)
				emit(0)
				cmpl(node.kids[2])
			bytecode[a] = len(bytecode)

		elif node.type == "use":
			emit("IMM")
			emit(node.var.address)
			emit("LI")

		elif node.type == "call":
			emit("CALL")
			linking.append((node.func, len(bytecode)))
			emit(0)

		elif node.type == "=":
			# lvalue check for node.kids[0]
			assert node.kids[0].is_lvalue()
			cmpl(node.kids[0])
			bytecode.pop()
			emit("PUSH")
			cmpl(node.kids[1])
			emit("SI")

		elif node.type == "number":
			emit("IMM")
			emit(node.number)

		elif node.type == "neg":
			emit("NEG")

		elif node.type == "not":
			emit("NOT")

		elif node.type in OPCODES:
			cmpl(node.kids[0])
			emit("PUSH")
			cmpl(node.kids[1])
			emit(OPCODES.index(node.type))

		else:
			assert False, "TODO: compile node type %r" % node.type

	for k in prog.kids:
		if k.type == "var":
			k.address = var_offset
			var_offset += 1
		elif k.type == "func":
			cmpl(k)
		else:
			assert False

	for n, a in linking:
		bytecode[a] = n.address

	return bytecode


if __name__ == "__main__":

	code = file("test.c").read()
	ast = Parser(code).parse()
	resolve_names(ast)
	check_types(ast)
	fold_constants(ast)
	ast.pretty_print()

	bytecode = compile(ast)
	file("bytecode", "w").write("".join(struct.pack("@i", x) for x in bytecode))

	i = 0
	while i < len(bytecode):
		b = OPCODES_[bytecode[i]]
		print "%3d\t%s\t" % (i, b),
		i += 1
		if b in ["JMP", "JZ", "JNZ", "IMM"]:
			print bytecode[i],
			i += 1
		print
